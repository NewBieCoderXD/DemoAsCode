{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node", "jsdom"],
    "lib": ["ES2022"],

    "outDir": "./dist",
    "rootDir": "./",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": { "~/*": ["./cli-src/*"] }
  },
  "include": ["cli-src/**/*"],
  "exclude": ["node_modules", "dist"]
}
